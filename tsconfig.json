{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "strict": true,
        "skipLibCheck": true,
        "rootDir": "./src",
        "declarationDir": "dist",
        "outDir": "./dist",
        "emitDeclarationOnly": true,
        "isolatedModules": true,
        "declaration": true,
        "declarationMap": false
    },
    "include": [
        "src"
    ]
}